# Sensgreen Sensor Simulator — environment variables
# Copy this file to `.env` and fill in real values. Do NOT commit `.env`.

# --- Run mode -----------------------------------------------------------------
# live | historical
SIMULATOR_MODE=live

# --- Config -------------------------------------------------------------------
SIMULATOR_CONFIG_PATH=configs/default.yaml

# --- Sensgreen MQTT broker (live mode) ---------------------------------------
MQTT_HOST=broker.example.sensgreen.com
MQTT_PORT=8883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=sensgreen-simulator
MQTT_TLS=true

# --- Historical export (historical mode) -------------------------------------
HISTORICAL_OUTPUT_DIR=outputs
HISTORICAL_START=2026-01-01T00:00:00Z
HISTORICAL_END=2026-01-07T00:00:00Z

# --- Logging ------------------------------------------------------------------
LOG_LEVEL=INFO
