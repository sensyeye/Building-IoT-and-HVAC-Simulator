# Version control
.git
.gitignore

# Python
__pycache__
*.py[cod]
*.egg-info
.eggs
build
dist
.pytest_cache
.mypy_cache
.ruff_cache

# Virtual envs
.venv
venv
env

# IDE / OS
.vscode
.idea
.DS_Store

# Local data + generated artifacts (anchored to repo root so we don't
# accidentally exclude `simulator/outputs/` which is a Python module).
/data
/outputs
/output
*.log
*.jsonl

# Belt-and-suspenders: explicitly RE-INCLUDE the simulator's Python
# source tree even if a parent rule above tried to exclude it.
!simulator/
!simulator/**
!api/
!api/**

# Tests aren't needed in the runtime image
tests

# Local env files
.env
*.env.local
